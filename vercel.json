{
  "version": 2,
  "builds": [
    {
      "src": "ahmed-adel/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "ahmed-adel-api/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "ahmed-adel-api/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "ahmed-adel/$1"
    }
  ]
}
